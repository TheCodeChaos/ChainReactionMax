---
import BackToTop from '../components/BackToTop.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
---

<Layout title="Privacy" description="Privacy notes for the Chain Reaction MAX app and website.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container privacy-page" data-pagefind-body>
      <section class="section legal-panel" data-reveal>
        <span class="eyebrow">Privacy</span>
        <h1 class="page-title">Local-first by design.</h1>
        <p class="lede">
          Chain Reaction MAX does not currently rely on a remote backend or third-party analytics layer.
          The Flutter codebase focuses on local gameplay and same-network matchmaking.
        </p>

        <div class="privacy-strip" aria-label="Privacy summary">
          <span><strong>No analytics SDK</strong></span>
          <span><strong>No hosted search API</strong></span>
          <span><strong>LAN traffic only for matches</strong></span>
        </div>

        <div class="legal-copy section-tight">
          <article class="policy-row">
            <span>01</span>
            <div>
              <h2>Data collection</h2>
            <p>
              The current app code does not indicate a remote analytics SDK, ad SDK, or hosted account
              service. Normal matches run on-device.
            </p>
            </div>
          </article>

          <article class="policy-row">
            <span>02</span>
            <div>
              <h2>LAN play</h2>
            <p>
              Host and join messages are exchanged over the same local network to discover rooms and start
              matches. That traffic is gameplay, not telemetry.
            </p>
            </div>
          </article>

          <article class="policy-row">
            <span>03</span>
            <div>
              <h2>Website search</h2>
            <p>
              This website uses Pagefind, which builds a static index during build time. Search runs in the
              browser and does not depend on a hosted search API.
            </p>
            </div>
          </article>

          <article class="policy-row">
            <span>04</span>
            <div>
              <h2>Repository workflows</h2>
            <p>
              Opening issues or tracking releases happens on GitHub, and those actions follow GitHub's own
              privacy policies.
            </p>
            </div>
          </article>

          <article class="policy-row">
            <span>05</span>
            <div>
              <h2>Changes</h2>
            <p>
              If future versions add cloud sync, remote multiplayer, or telemetry, this page should be
              updated before those features are announced as active.
            </p>
            </div>
          </article>
        </div>
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .privacy-page {
    display: grid;
    gap: 0;
  }

  .legal-panel {
    display: grid;
    gap: 0.95rem;
  }

  .privacy-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .privacy-strip span {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .privacy-strip strong {
    color: var(--text);
    font-weight: 550;
  }

  .legal-copy {
    display: grid;
    gap: 0;
  }

  .legal-copy h2 {
    margin: 0 0 0.5rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: 1.26rem;
    line-height: 1.08;
  }

  .legal-copy p {
    margin: 0;
    color: var(--text-muted);
  }

  .policy-row {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 0.75rem;
    padding: 0.95rem 0;
    border-top: 1px solid var(--line-soft);
  }

  .policy-row span {
    color: var(--text-soft);
    font-size: 0.76rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding-top: 0.4rem;
  }

  @media (max-width: 760px) {
    .policy-row {
      grid-template-columns: 1fr;
      gap: 0.45rem;
    }

    .policy-row span {
      padding-top: 0;
    }
  }
</style>
