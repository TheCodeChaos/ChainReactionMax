---
import BackToTop from '../components/BackToTop.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { credits } from '../data/site';
---

<Layout title="Credits" description="Libraries and tools behind Chain Reaction MAX and its website.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container credits-page" data-pagefind-body>
      <section class="section credits-hero" data-reveal>
        <span class="eyebrow">Credits</span>
        <h1 class="page-title">The stack behind the chain.</h1>
        <p class="lede">
          This page gives proper credit to the frameworks, libraries, and design choices that power both
          the game and this documentation site.
        </p>

        <div class="credit-strip" aria-label="Credits summary">
          <span><strong>{credits.length}</strong> credit groups</span>
          <span><strong>{credits.reduce((count, group) => count + group.items.length, 0)}</strong> total acknowledgements</span>
        </div>
      </section>

      <section class="section credits-list" data-reveal>
        {
          credits.map((group, index) => (
            <article class="credit-card">
              <p class="credit-index">0{index + 1}</p>
              <h2>{group.title}</h2>
              <ul>
                {group.items.map(item => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .credits-page {
    display: grid;
    gap: 0;
  }

  .credits-list {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .credit-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .credit-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .credit-strip strong {
    color: var(--text);
    font-weight: 600;
  }

  .credit-card {
    position: relative;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    padding: 1rem 1rem 1.05rem;
    background:
      radial-gradient(circle at 80% 20%, rgba(141, 247, 75, 0.12), transparent 38%),
      color-mix(in srgb, var(--panel) 84%, transparent);
    overflow: hidden;
  }

  .credit-card::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 44%;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-2), transparent 82%);
  }

  .credit-index {
    margin: 0 0 0.35rem;
    color: var(--text-soft);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .credit-card h2 {
    margin: 0 0 0.6rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: 1.3rem;
    line-height: 1.08;
  }

  .credit-card ul {
    margin: 0;
    padding-left: 1.05rem;
    color: var(--text-muted);
    border-top: 1px solid var(--line-soft);
    padding-top: 0.65rem;
    line-height: 1.6;
  }

  .credit-card li + li {
    margin-top: 0.45rem;
  }

  @media (max-width: 940px) {
    .credits-list {
      grid-template-columns: 1fr;
    }
  }
</style>
