---
import BackToTop from '../components/BackToTop.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { credits } from '../data/site';
---

<Layout title="Credits" description="Libraries and tools behind Chain Reaction MAX and its website.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container credits-page" data-pagefind-body>
      <section class="section credits-hero" data-reveal>
        <span class="eyebrow">Credits</span>
        <h1 class="page-title">The stack behind the chain.</h1>
        <p class="lede">
          This page gives proper credit to the frameworks, libraries, and design choices that power both
          the game and this documentation site.
        </p>

        <div class="credit-strip" aria-label="Credits summary">
          <span><strong>{credits.length}</strong> credit groups</span>
          <span><strong>{credits.reduce((count, group) => count + group.items.length, 0)}</strong> total acknowledgements</span>
        </div>
      </section>

      <section class="section credits-list" data-reveal>
        <div class="credit-groups">
        {
          credits.map((group, index) => (
            <article class="credit-group" style={`--group-index:${index};`}>
              <p class="credit-label">0{index + 1}</p>
              <h2>{group.title}</h2>
              <ul>
                {group.items.map(item => <li>{item}</li>)}
              </ul>
            </article>
          ))
        }
        </div>
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .credits-page {
    display: grid;
    gap: 0;
  }

  .credits-list {
    display: grid;
    gap: 1rem;
  }

  .credit-groups {
    display: grid;
    gap: 0.95rem;
  }

  .credit-group {
    position: relative;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    padding: 1rem;
    background:
      radial-gradient(
        circle at calc(84% - var(--group-index) * 11%) 26%,
        rgba(62, 194, 255, 0.15),
        transparent 36%
      ),
      color-mix(in srgb, var(--panel) 84%, transparent);
    overflow: hidden;
  }

  .credit-group::before {
    content: '';
    position: absolute;
    inset: 0 auto auto 0;
    width: 44%;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), transparent 82%);
  }

  .credit-label {
    margin: 0 0 0.36rem;
    color: var(--text-soft);
    font-size: 0.73rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .credit-group h2 {
    margin: 0 0 0.7rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: clamp(1.35rem, 2.1vw, 1.75rem);
    line-height: 1.08;
  }

  .credit-group ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.6rem;
  }

  .credit-group li {
    border: 1px solid var(--line-soft);
    border-radius: 12px;
    padding: 0.62rem 0.68rem;
    background: color-mix(in srgb, var(--bg-panel) 74%, transparent);
    color: var(--text-muted);
    line-height: 1.5;
  }

  .credit-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .credit-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .credit-strip strong {
    color: var(--text);
    font-weight: 600;
  }

  @media (min-width: 1020px) {
    .credit-groups {
      grid-template-columns: repeat(12, minmax(0, 1fr));
      gap: 1rem;
    }

    .credit-group {
      grid-column: span 6;
    }

    .credit-group:nth-child(3n) {
      grid-column: span 12;
    }

    .credit-group:nth-child(3n) ul {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
