---
import BackToTop from '../components/BackToTop.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { credits } from '../data/site';
---

<Layout title="Credits" description="Libraries and tools behind Chain Reaction MAX and its website.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container credits-page" data-pagefind-body>
      <section class="section credits-hero" data-reveal>
        <span class="eyebrow">Credits</span>
        <h1 class="page-title">The stack behind the chain.</h1>
        <p class="lede">
          This page gives proper credit to the frameworks, libraries, and design choices that power both
          the game and this documentation site.
        </p>

        <div class="credit-strip" aria-label="Credits summary">
          <span><strong>{credits.length}</strong> credit groups</span>
          <span><strong>{credits.reduce((count, group) => count + group.items.length, 0)}</strong> total acknowledgements</span>
        </div>
      </section>

      <section class="section credits-board" data-reveal>
        <aside class="credits-intro">
          <p class="eyebrow">Acknowledgements</p>
          <h2>Built with open tools and practical foundations.</h2>
          <p>
            Every release is shaped by these frameworks, libraries, and design decisions.
          </p>
        </aside>

        <div class="credits-rail">
          {
            credits.map((group, index) => (
              <article class="credit-row">
                <div class="credit-head">
                  <p class="credit-index">0{index + 1}</p>
                  <h3>{group.title}</h3>
                </div>
                <ul>
                  {group.items.map(item => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .credits-page {
    display: grid;
    gap: 0;
  }

  .credits-board {
    display: grid;
    gap: 1.1rem;
  }

  .credit-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .credit-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .credit-strip strong {
    color: var(--text);
    font-weight: 600;
  }

  .credits-intro {
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-md);
    padding: 1rem;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
    height: fit-content;
  }

  .credits-intro h2 {
    margin: 0 0 0.5rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: clamp(1.3rem, 2.4vw, 1.95rem);
    line-height: 1.08;
  }

  .credits-intro p {
    margin: 0;
    color: var(--text-muted);
  }

  .credits-intro .eyebrow {
    margin-bottom: 0.7rem;
  }

  .credits-rail {
    border-top: 1px solid var(--line-soft);
  }

  .credit-row {
    position: relative;
    display: grid;
    grid-template-columns: minmax(170px, 210px) 1fr;
    gap: 0.95rem;
    padding: 1rem 0;
    border-bottom: 1px solid var(--line-soft);
  }

  .credit-row::before {
    content: '';
    position: absolute;
    inset: -1px auto auto 0;
    width: 160px;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-2), transparent 82%);
  }

  .credit-head {
    display: grid;
    gap: 0.32rem;
    align-content: start;
  }

  .credit-index {
    margin: 0 0 0.35rem;
    color: var(--text-soft);
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .credit-head h3 {
    margin: 0;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: 1.22rem;
    line-height: 1.08;
  }

  .credit-row ul {
    margin: 0;
    padding-left: 1.05rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  .credit-row li + li {
    margin-top: 0.45rem;
  }

  @media (min-width: 1020px) {
    .credits-board {
      grid-template-columns: minmax(0, 320px) minmax(0, 1fr);
      align-items: start;
    }

    .credits-intro {
      position: sticky;
      top: calc(var(--nav-height) + 1.4rem);
    }
  }

  @media (max-width: 940px) {
    .credit-row {
      grid-template-columns: 1fr;
      gap: 0.55rem;
    }
  }
</style>
