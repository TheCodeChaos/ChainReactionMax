---
import { getCollection } from 'astro:content';
import AuthorBadge from '../../components/AuthorBadge.astro';
import BackToTop from '../../components/BackToTop.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<Layout title="Blog" description="Strategy notes, release thoughts, and setup guides for Chain Reaction MAX.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container blog-page" data-pagefind-body>
      <section class="section blog-hero" data-reveal>
        <span class="eyebrow">Blog</span>
        <h1 class="page-title">Simple notes to help you play better.</h1>
        <p class="lede">
          Every post is short, practical, and focused on gameplay decisions that matter in real matches.
        </p>

        <div class="blog-strip" aria-label="Blog summary">
          <span><strong>{posts.length}</strong> total posts</span>
          <span><strong>{new Set(posts.flatMap(post => post.data.tags)).size}</strong> active tags</span>
        </div>
      </section>

      <section class="section blog-list" data-reveal>
        {
          posts.map(post => (
            <article class="post-row">
              <div class="post-meta">
                <FormattedDate date={post.data.pubDate} />
              </div>
              <div class="post-main">
                <h2>
                  <a href={`${import.meta.env.BASE_URL}/blog/${post.id}/`.replace(/\/\//g, '/')}>
                    {post.data.title}
                  </a>
                </h2>
                <p>{post.data.description}</p>
                <div class="tag-row">
                  {post.data.tags.map(tag => <span class="tag">{tag}</span>)}
                </div>
                <div class="tag-row">
                  {post.data.authors.map(author => <AuthorBadge authorId={author as 'ayaan' | 'shravan'} />)}
                </div>
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .blog-page {
    display: grid;
    gap: 0;
  }

  .blog-hero {
    display: grid;
    gap: 0.95rem;
  }

  .blog-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .blog-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .blog-strip strong {
    color: var(--text);
    font-weight: 600;
  }

  .blog-list {
    display: grid;
    gap: 0;
  }

  .post-row {
    display: grid;
    grid-template-columns: minmax(130px, 170px) 1fr;
    gap: 0.9rem;
    align-items: start;
    padding: 1.15rem 0;
    border-top: 1px solid var(--line-soft);
  }

  .post-row:last-child {
    border-bottom: 1px solid var(--line-soft);
  }

  .post-meta {
    padding-top: 0.36rem;
  }

  .post-main {
    display: grid;
    gap: 0.52rem;
  }

  .post-main h2 {
    margin: 0;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: clamp(1.35rem, 2.3vw, 1.75rem);
    line-height: 1.1;
  }

  .post-main p {
    margin: 0;
    color: var(--text-muted);
  }

  @media (max-width: 780px) {
    .post-row {
      grid-template-columns: 1fr;
      gap: 0.48rem;
      padding: 1rem 0;
    }

    .post-meta {
      padding-top: 0;
    }
  }
</style>
