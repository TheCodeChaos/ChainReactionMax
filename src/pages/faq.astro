---
import BackToTop from '../components/BackToTop.astro';
import FAQList from '../components/FAQList.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Layout from '../layouts/Layout.astro';
import { faqItems } from '../data/site';
---

<Layout title="FAQ" description="Frequently asked questions about Chain Reaction MAX.">
  <SiteHeader />

  <div class="page-shell">
    <main class="container faq-page" data-pagefind-body>
      <section class="section faq-hero" data-reveal>
        <span class="eyebrow">FAQ</span>
        <h1 class="page-title">Rules, rooms, and match logic.</h1>
        <p class="lede">
          Everything here maps to the current codebase and app flow, from critical-cell rules to
          replay behavior.
        </p>

        <div class="faq-strip" aria-label="FAQ summary">
          <span><strong>{faqItems.length}</strong> total answers</span>
          <span><strong>0 fluff</strong> sentences</span>
        </div>
      </section>

      <section class="section faq-body" data-reveal>
        <FAQList items={faqItems} />
      </section>
    </main>
  </div>

  <BackToTop />
  <SiteFooter />
</Layout>

<style>
  .faq-page {
    display: grid;
    gap: 0;
  }

  .faq-hero {
    display: grid;
    gap: 0.95rem;
  }

  .faq-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.7rem;
  }

  .faq-strip span {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    padding: 0.26rem 0.7rem;
    color: var(--text-soft);
    font-size: 0.82rem;
    letter-spacing: 0.03em;
    background: color-mix(in srgb, var(--panel) 82%, transparent);
  }

  .faq-strip strong {
    color: var(--text);
    font-weight: 600;
  }

  .faq-body {
    padding-top: 0;
  }
</style>
