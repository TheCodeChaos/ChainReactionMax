---
import { GitBranch, Menu, Moon, Search, Sun, X } from '@lucide/astro';
import { navLinks, siteConfig } from '../data/site';
import SearchModal from './SearchModal.astro';

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function isActive(href: string) {
  const normalizedHref = href === '/' ? '/' : href.replace(/\/$/, '');
  return currentPath === normalizedHref || currentPath.startsWith(`${normalizedHref}/`);
}
---

<header class="site-header" data-pagefind-ignore>
  <div class="container header-inner">
    <a href={`${import.meta.env.BASE_URL}/`.replace(/\/\//g, '/')} class="brand-link">
      <img
        class="brand-logo"
        src={`${import.meta.env.BASE_URL}/favicon.svg`.replace(/\/\//g, '/')}
        alt=""
        aria-hidden="true"
      />
      <span class="brand-copy">
        <strong>{siteConfig.shortName}</strong>
      </span>
    </a>

    <nav class="desktop-nav" aria-label="Primary navigation">
      {
        navLinks.map(link => (
          <a
            href={`${import.meta.env.BASE_URL}${link.href}`.replace(/\/\//g, '/')}
            class:list={['nav-link', { active: isActive(link.href) }]}
          >
            {link.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <button class="search-link" type="button" data-open-search aria-label="Search the site">
        <Search size={16} /> Search
      </button>
      <a href={siteConfig.repoUrl} class="repo-link" target="_blank" rel="noreferrer">
        <GitBranch size={16} /> Repo
      </a>
      <button class="theme-toggle" id="theme-toggle" type="button" aria-label="Toggle theme">
        <Sun size={17} class="sun-icon" />
        <Moon size={17} class="moon-icon" />
      </button>
      <button class="menu-toggle" id="menu-toggle" type="button" aria-label="Toggle navigation">
        <Menu size={19} class="menu-open" />
        <X size={19} class="menu-close" />
      </button>
    </div>
  </div>

  <div class="container mobile-panel" id="mobile-panel">
    <div class="mobile-panel-head">
      <p>Menu</p>
      <button class="mobile-search-cta" type="button" data-open-search>
        <Search size={15} /> Search
      </button>
    </div>
    <nav class="mobile-nav" aria-label="Mobile navigation">
      {
        navLinks.map(link => (
          <a
            href={`${import.meta.env.BASE_URL}${link.href}`.replace(/\/\//g, '/')}
            class:list={['mobile-link', { active: isActive(link.href) }]}
          >
            {link.label}
          </a>
        ))
      }
      <a href={siteConfig.repoUrl} class="mobile-link" target="_blank" rel="noreferrer">
        Project repository
      </a>
    </nav>
  </div>

  <SearchModal />
</header>

<script>
  const root = document.documentElement;
  const menuToggle = document.getElementById('menu-toggle');
  const mobilePanel = document.getElementById('mobile-panel');
  const themeToggle = document.getElementById('theme-toggle');

  const setTheme = (theme: string) => {
    root.dataset.theme = theme;
    localStorage.setItem('crmax-theme', theme);
  };

  themeToggle?.addEventListener('click', () => {
    const nextTheme = root.dataset.theme === 'light' ? 'dark' : 'light';
    setTheme(nextTheme);
  });

  menuToggle?.addEventListener('click', () => {
    const isOpen = mobilePanel?.classList.toggle('open');
    menuToggle.classList.toggle('active', Boolean(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  document.querySelectorAll('.mobile-link').forEach(link => {
    link.addEventListener('click', () => {
      mobilePanel?.classList.remove('open');
      menuToggle?.classList.remove('active');
      document.body.style.overflow = '';
    });
  });

</script>

<style>
  .site-header {
    position: fixed;
    inset: 0 0 auto;
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    border-bottom: 1px solid var(--line-soft);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }

  .header-inner {
    min-height: var(--nav-height);
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1.2rem;
  }

  .brand-link {
    display: inline-flex;
    align-items: center;
    gap: 0.58rem;
  }

  .brand-logo {
    width: 1.78rem;
    height: 1.78rem;
    border-radius: 8px;
    border: 1px solid var(--line-soft);
    flex: 0 0 auto;
  }

  .brand-copy {
    display: inline-flex;
    align-items: center;
    line-height: 1.05;
  }

  .brand-copy strong {
    font-family: 'Fraunces', 'Outfit', serif;
    letter-spacing: -0.01em;
    font-size: 1.02rem;
  }

  .desktop-nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.45rem;
  }

  .nav-link {
    color: var(--text-muted);
    padding: 0.35rem 0.62rem;
    border-radius: 999px;
    font-size: 0.9rem;
    letter-spacing: 0.01em;
    transition: color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    background: rgba(255, 255, 255, 0.06);
    color: var(--text);
    transform: translateY(-1px);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.45rem;
  }

  .search-link,
  .repo-link,
  .theme-toggle,
  .menu-toggle {
    border: 1px solid var(--line-soft);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.03);
    min-height: 39px;
  }

  .search-link,
  .repo-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.82rem;
    color: var(--text-muted);
    font-size: 0.86rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
  }

  .search-link:hover,
  .repo-link:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--accent) 55%, var(--line));
    background: rgba(255, 124, 57, 0.12);
  }

  .theme-toggle,
  .menu-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 39px;
    padding: 0;
    cursor: pointer;
  }

  .moon-icon,
  .menu-close {
    display: none;
  }

  :global([data-theme='light']) .moon-icon {
    display: block;
  }

  :global([data-theme='light']) .sun-icon {
    display: none;
  }

  .menu-toggle.active .menu-open {
    display: none;
  }

  .menu-toggle.active .menu-close {
    display: block;
  }

  .menu-toggle,
  .mobile-panel {
    display: none;
  }

  .mobile-panel {
    padding: 0.75rem;
  }

  .mobile-panel.open {
    display: block;
  }

  .mobile-panel-head {
    display: none;
  }

  .mobile-nav {
    display: grid;
    gap: 0.55rem;
  }

  .mobile-link {
    display: block;
    padding: 0.66rem 0.4rem;
    border-radius: 10px;
    color: var(--text-muted);
    border: 1px solid transparent;
    text-align: left;
    background: transparent;
    width: 100%;
    font: inherit;
    cursor: pointer;
  }

  .mobile-link.active,
  .mobile-link:hover {
    color: var(--text);
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--line-soft);
  }

  @media (max-width: 1080px) {
    .desktop-nav {
      display: none;
    }
  }

  @media (max-width: 820px) {
    .header-inner {
      grid-template-columns: auto 1fr;
      gap: 0.75rem;
    }

    .header-actions {
      order: -1;
      justify-content: flex-start;
    }

    .brand-link {
      justify-self: center;
    }

    .search-link,
    .repo-link {
      display: none;
    }

    .menu-toggle {
      display: inline-flex;
    }

    .mobile-panel {
      position: absolute;
      top: calc(var(--nav-height) - 0.15rem);
      left: 0.6rem;
      right: auto;
      width: min(90vw, 360px);
      border: 1px solid var(--line-soft);
      border-radius: 14px;
      background: color-mix(in srgb, var(--bg-panel) 98%, transparent);
      box-shadow: 0 12px 38px rgba(5, 12, 30, 0.35);
      -webkit-backdrop-filter: blur(14px);
      backdrop-filter: blur(14px);
    }

    .mobile-panel-head {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 0.65rem;
      margin-bottom: 0.55rem;
    }

    .mobile-panel-head p {
      margin: 0;
      color: var(--text-soft);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      font-size: 0.74rem;
    }

    .mobile-search-cta {
      border: 1px solid var(--line-soft);
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.04);
      color: var(--text-muted);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      padding: 0.28rem 0.72rem;
      font-size: 0.78rem;
      cursor: pointer;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .mobile-search-cta:hover {
      color: var(--text);
      border-color: var(--line);
    }

    .mobile-nav {
      gap: 0.4rem;
    }

    .mobile-link {
      padding: 0.58rem 0.5rem;
      font-size: 0.92rem;
    }
  }

  @media (max-width: 580px) {
    .brand-copy strong {
      font-size: 0.95rem;
    }
  }
</style>
