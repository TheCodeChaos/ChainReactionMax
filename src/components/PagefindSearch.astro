---
interface Props {
  label?: string;
  idPrefix?: string;
}

const { label = 'Search the site', idPrefix = 'pagefind' } = Astro.props;

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
const bundlePath = `${baseUrl}/pagefind/`.replace(/\/\//g, '/');
const searchContainerId = `${idPrefix}-search`;
const statusId = `${idPrefix}-status`;
---

<div class="search-shell" id={`${idPrefix}-root`} data-pagefind-root data-bundle-path={bundlePath}>
  <div class="search-header">
    <span class="eyebrow">Pagefind</span>
    <h2>{label}</h2>
    <p>
      Search blog posts, FAQs, product copy, support notes, and page titles from one place.
    </p>
  </div>
  <div id={searchContainerId} data-pagefind-container></div>
  <p class="search-status" id={statusId} data-pagefind-status>
    Search loads automatically in production builds after Pagefind indexes the site.
  </p>
</div>

<script>
  import { PagefindUI } from '@pagefind/default-ui';
  import '@pagefind/default-ui/css/ui.css';

  const bootRoot = async (root: HTMLElement) => {
    if (root.dataset.pagefindReady === 'true' || root.dataset.pagefindBooting === 'true') {
      return;
    }

    const container = root.querySelector('[data-pagefind-container]');
    const status = root.querySelector('[data-pagefind-status]');

    if (!(container instanceof HTMLElement) || !container.id) {
      return;
    }

    root.dataset.pagefindBooting = 'true';

    try {
      new PagefindUI({
        element: `#${container.id}`,
        bundlePath: root.dataset.bundlePath || '/pagefind/',
        showSubResults: true,
        excerptLength: 18,
        pageSize: 8,
        autofocus: false,
        resetStyles: false,
        translations: {
          placeholder: 'Search for rules, tips, and support topics...',
        },
      });

      root.dataset.pagefindReady = 'true';
      status?.remove();
    } catch (_error) {
      if (status instanceof HTMLElement) {
        status.textContent =
          'Search is available after running a production build with Pagefind indexing.';
      }
    } finally {
      root.dataset.pagefindBooting = 'false';
    }
  };

  const initAll = () => {
    document.querySelectorAll('[data-pagefind-root]').forEach(root => {
      if (root instanceof HTMLElement) {
        bootRoot(root);
      }
    });
  };

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initAll, { once: true });
  } else {
    initAll();
  }
</script>

<style is:global>
  .search-shell {
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background: var(--bg-panel);
    padding: 1.15rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .search-header h2 {
    margin: 0.28rem 0 0.52rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: clamp(1.7rem, 4vw, 2.35rem);
    line-height: 1.07;
  }

  .search-header p,
  .search-status {
    margin: 0;
    color: var(--text-muted);
  }

  .search-status {
    margin-top: 1rem;
  }

  .pagefind-ui {
    margin-top: 1.1rem;
  }

  .pagefind-ui__search-input {
    width: 100%;
    border-radius: 12px;
    border: 1px solid var(--line-soft) !important;
    box-shadow: none;
    background: color-mix(in srgb, var(--panel) 92%, transparent) !important;
    color: var(--text) !important;
    min-height: 54px;
    padding-left: 2.65rem !important;
    padding-right: 2.85rem !important;
  }

  .pagefind-ui__search-input::placeholder {
    color: var(--text-soft) !important;
  }

  .pagefind-ui__search-clear {
    border-radius: 999px !important;
    border: 1px solid var(--line-soft) !important;
    background: color-mix(in srgb, var(--panel) 88%, transparent) !important;
    color: var(--text-soft) !important;
    width: 1.9rem !important;
    height: 1.9rem !important;
    display: inline-flex !important;
    align-items: center;
    justify-content: center;
    right: 0.56rem !important;
  }

  .pagefind-ui__search-clear:hover {
    color: var(--text) !important;
    border-color: var(--line) !important;
  }

  .pagefind-ui__search-icon {
    color: var(--text-soft) !important;
    left: 0.95rem !important;
  }

  .pagefind-ui__drawer {
    margin-top: 1rem;
  }

  .pagefind-ui__message {
    color: var(--text-muted) !important;
  }

  .pagefind-ui__result {
    border-radius: 12px;
    border: 1px solid var(--line-soft);
    box-shadow: none;
    background: rgba(255, 255, 255, 0.02);
    padding: 0.85rem 0.95rem;
    margin-top: 0.75rem;
  }

  .pagefind-ui__result-link {
    color: var(--text) !important;
    font-weight: 700;
  }

  .pagefind-ui__result-excerpt {
    color: var(--text-muted) !important;
  }

  .pagefind-ui__result-thumb {
    display: none;
  }

  .pagefind-ui__button {
    border-radius: 999px !important;
    border: 1px solid var(--line-soft) !important;
    box-shadow: none;
    background: transparent !important;
    color: var(--text) !important;
  }

  @media (max-width: 720px) {
    .search-shell {
      padding: 0.9rem;
      border-radius: var(--radius-md);
    }
  }
</style>
