---
import { GitBranch, Rss, Search } from '@lucide/astro';
import { navLinks, quickFacts, siteConfig } from '../data/site';
---

<footer class="site-footer section" data-pagefind-ignore>
  <div class="container footer-wrap">
    <div class="footer-top">
      <div class="footer-brand">
        <span class="eyebrow">Chain Reaction MAX</span>
        <h2>Designed for dramatic swings and clean strategy reading.</h2>
        <p>
          Product pages, support flow, searchable docs, and tactics writing are all tuned for quick scanning
          without visual clutter.
        </p>
      </div>

      <div class="footer-links">
        <div>
          <h3>Explore</h3>
          {
            navLinks.map(link => (
              <a href={`${import.meta.env.BASE_URL}${link.href}`.replace(/\/\//g, '/')}>
                {link.label}
              </a>
            ))
          }
        </div>

        <div>
          <h3>Project</h3>
          <a href={siteConfig.repoUrl} target="_blank" rel="noreferrer">
            <GitBranch size={16} /> Repository
          </a>
          <a href={siteConfig.issuesUrl} target="_blank" rel="noreferrer">
            Report issue
          </a>
          <a href={siteConfig.releasesUrl} target="_blank" rel="noreferrer">
            Releases
          </a>
          <a href={`${import.meta.env.BASE_URL}/rss.xml`.replace(/\/\//g, '/')}>
            <Rss size={16} /> RSS
          </a>
        </div>

        <div>
          <h3>Quick facts</h3>
          {
            quickFacts.map(fact => (
              <p><strong>{fact.value}</strong> {fact.label}</p>
            ))
          }
          <button type="button" class="footer-search" data-open-search>
            <Search size={16} /> Search
          </button>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <span>© 2026 Chain Reaction MAX</span>
      <a href={`${import.meta.env.BASE_URL}/privacy`.replace(/\/\//g, '/')}>Privacy</a>
      <a href={`${import.meta.env.BASE_URL}/credits`.replace(/\/\//g, '/')}>Credits</a>
    </div>
  </div>
</footer>

<style>
  .footer-wrap {
    border-top: 1px solid var(--line-soft);
    padding-top: 1.6rem;
  }

  .footer-top {
    display: grid;
    gap: 2rem;
    border: 1px solid var(--line-soft);
    border-radius: var(--radius-lg);
    background: var(--bg-panel);
    padding: 1.4rem;
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .footer-brand h2 {
    margin: 0 0 0.7rem;
    font-family: 'Fraunces', 'Outfit', serif;
    font-size: clamp(1.5rem, 4vw, 2.35rem);
    line-height: 1.08;
  }

  .footer-brand p {
    margin: 0;
    max-width: 52ch;
    color: var(--text-muted);
  }

  .footer-links {
    display: grid;
    gap: 1.25rem;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
  }

  .footer-links h3 {
    margin: 0 0 0.65rem;
    color: var(--text);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.11em;
  }

  .footer-links a,
  .footer-links p {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    margin: 0 0 0.52rem;
    color: var(--text-muted);
    font-size: 0.9rem;
  }

  .footer-search {
    margin: 0 0 0.52rem;
    padding: 0;
    border: 0;
    background: transparent;
    color: var(--text-muted);
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font: inherit;
    cursor: pointer;
  }

  .footer-links strong {
    color: var(--text);
    margin-right: 0.22rem;
  }

  .footer-links a:hover {
    color: var(--text);
  }

  .footer-search:hover {
    color: var(--text);
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem 1.15rem;
    margin-top: 1.1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line-soft);
    color: var(--text-soft);
    font-size: 0.9rem;
  }

  .footer-bottom a:hover {
    color: var(--text);
  }

  @media (min-width: 900px) {
    .footer-top {
      grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
      align-items: start;
    }
  }

  @media (max-width: 720px) {
    .footer-top {
      padding: 1.1rem;
    }
  }
</style>
